{
  "name": "hop-top/cite",
  "description": "Custom URI scheme utilities (polyglot).",
  "type": "library",
  "license": "MIT",
  "homepage": "https://hop.top/cite",
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Hop\\Cite\\": "src/"
    },
    "files": [
      "src/Scheme.php",
      "src/Handle.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Hop\\Cite\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
